# Copy to .env and fill in. .env is gitignored — never commit a real token.

# A Hugging Face token with WRITE access to your namespace, used by
# publish/ to upload quantized checkpoints. Create one at
# https://huggingface.co/settings/tokens (type: Write).
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: the HF namespace publish/ uploads to (default: seoilgun).
# FASTSERVE_HF_NAMESPACE=your-username

# Optional: comma-separated namespaces detect.py prefers over community
# requants (default: seoilgun). Point this at your own published set.
# FASTSERVE_TRUSTED_NAMESPACES=your-username
